{
    "tasks": [
         {
            "type": "cppbuild",
            "label": "C/C++: clang++ build active file",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "${workspaceFolder}/circuit-model/*.cpp",
                "${workspaceFolder}/circuit-model/jsonParser/*.cpp",
                "${workspaceFolder}/circuit-model/cliffordOperations/*.cpp",
                "${workspaceFolder}/circuit-model/measurements/*.cpp",
                "${workspaceFolder}/circuit-model/stateStreams/*.cpp",
                "${workspaceFolder}/logging/*.cpp",
                "${workspaceFolder}/utils/*.cpp",
                "${workspaceFolder}/test_classes/*.cpp",
                "${workspaceFolder}/tests/unit_tests/*.cpp",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-I",
                "/opt/homebrew/Cellar/eigen/5.0.1/include"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build active file",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "${workspaceFolder}/circuit-model/*.cpp",
                "${workspaceFolder}/circuit-model/jsonParser/*.cpp",
                "${workspaceFolder}/circuit-model/cliffordOperations/*.cpp",
                "${workspaceFolder}/circuit-model/measurements/*.cpp",
                "${workspaceFolder}/circuit-model/stateStreams/*.cpp",
                "${workspaceFolder}/logging/*.cpp",
                "${workspaceFolder}/utils/*.cpp",
                "${workspaceFolder}/test_classes/*.cpp",
                "${workspaceFolder}/tests/unit_tests/*.cpp",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}
